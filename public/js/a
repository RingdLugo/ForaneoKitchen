);

-- 7. Tabla para lista de compras (no existe)
CREATE TABLE IF NOT EXISTS public.lista_compras (
    id SERIAL PRIMARY KEY,
    usuario_id INTEGER REFERENCES public.usuarios(id) ON DELETE CASCADE UNIQUE,
    items JSONB DEFAULT '[]',
    updated_at TIMESTAMP DEFAULT NOW()
);

-- 8. Tabla para planes semanales unificados (alternativa a plan_semanal)
CREATE TABLE IF NOT EXISTS public.planes_semanales (
    id SERIAL PRIMARY KEY,
    usuario_id INTEGER REFERENCES public.usuarios(id) ON DELETE CASCADE UNIQUE,
    plan JSONB NOT NULL,
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW()
);

-- =====================================================
-- FUNCIONES RPC PARA LIKES (compatibles con tu esquema)
-- =====================================================

-- Función para agregar like
CREATE OR REPLACE FUNCTION public.agregar_like(p_receta_id INTEGER, p_usuario_id INTEGER)
RETURNS VOID AS $$
BEGIN
    INSERT INTO public.likes (user_id, recipe_id, created_at) 
    VALUES (p_usuario_id, p_receta_id, NOW());
    
    UPDATE public.recetas 
    SET likes = likes + 1 
    WHERE id = p_receta_id;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Función para eliminar like
CREATE OR REPLACE FUNCTION public.eliminar_like(p_receta_id INTEGER, p_usuario_id INTEGER)
RETURNS VOID AS $$
BEGIN
    DELETE FROM public.likes 
    WHERE recipe_id = p_receta_id AND user_id = p_usuario_id;
    
    UPDATE public.recetas 
    SET likes = likes - 1 
    WHERE id = p_receta_id AND likes > 0;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Función para agregar puntos
CREATE OR REPLACE FUNCTION public.add_puntos(uid INTEGER, pts INTEGER)
RETURNS VOID AS $$
BEGIN
    UPDATE public.usuarios 
    SET puntos = COALESCE(puntos, 0) + pts 
    WHERE id = uid;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- =====================================================
-- TRIGGERS
-- =====================================================

-- Trigger para updated_at en planes_semanales
CREATE OR REPLACE FUNCTION public.update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS update_planes_semanales_updated_at ON public.planes_semanales;
CREATE TRIGGER update_planes_semanales_updated_at
    BEFORE UPDATE ON public.planes_semanales
    FOR EACH ROW
    EXECUTE FUNCTION public.update_updated_at_column();

DROP TRIGGER IF EXISTS update_lista_compras_updated_at ON public.lista_compras;
CREATE TRIGGER update_lista_compras_updated_at
    BEFORE UPDATE ON public.lista_compras
    FOR EACH ROW
    EXECUTE FUNCTION public.update_updated_at_column();

