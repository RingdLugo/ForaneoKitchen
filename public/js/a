-- 1. Agregar puntos a usuarios (si no existe)
ALTER TABLE public.usuarios 
ADD COLUMN IF NOT EXISTS puntos INTEGER DEFAULT 0;

-- 2. Agregar rol a usuarios (free/premium/admin)
ALTER TABLE public.usuarios 
ADD COLUMN IF NOT EXISTS rol VARCHAR(20) DEFAULT 'free';

-- 3. Agregar premium_expira si se llama diferente
DO $$ 
BEGIN
    IF NOT EXISTS (SELECT 1 FROM information_schema.columns 
                   WHERE table_name = 'usuarios' AND column_name = 'premium_expira') THEN
        ALTER TABLE public.usuarios ADD COLUMN premium_expira TIMESTAMP;
    END IF;
END $$;

